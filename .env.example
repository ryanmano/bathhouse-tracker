# Copy to .env for local runs (never commit .env).
# In GitHub Actions these are repository secrets with the same names.

# Supabase project URL (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase service_role key (Project Settings -> API). Server-side secret —
# it bypasses row-level security. Do not expose it anywhere client-side.
SUPABASE_SERVICE_KEY=eyJ...
